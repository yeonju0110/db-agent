# 환경 설정
ENVIRONMENT=development
DEBUG=true

API_HOST=0.0.0.0
API_PORT=8000

# 고객사 DB 연결
TEST_CLIENT_DB_TYPE=postgres
TEST_CLIENT_DB_HOST=127.0.0.1
TEST_CLIENT_DB_PORT=5432
TEST_CLIENT_DB_NAME=ecommerce_db
TEST_CLIENT_DB_USER=monitoring_user
TEST_CLIENT_DB_PASSWORD=1234

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_API_KEY=your_admin_key
AZURE_SEARCH_INDEX_NAME=dbschema-tables

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your_api_key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
EMBEDDING_DIM=3072
