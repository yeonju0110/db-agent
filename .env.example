# ===========================================
# 기본 배포 설정
# ===========================================
RESOURCE_GROUP=
LOCATION=Korea Central
APP_NAME=db-agent
IMAGE_NAME=db-agent-backend

# ===========================================
# Azure Container Registry
# ===========================================
ACR_NAME=your_acr_name

# ===========================================
# 데이터베이스 연결 설정
# ===========================================
TEST_CLIENT_DB_HOST=your-postgres.postgres.database.azure.com
TEST_CLIENT_DB_PORT=5432
TEST_CLIENT_DB_NAME=ecommerce_db
TEST_CLIENT_DB_USER=monitoring_user
TEST_CLIENT_DB_PASSWORD=1234
TEST_CLIENT_DB_TYPE=postgres

# ===========================================
# Azure Cosmos DB
# ===========================================
COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-primary-key
COSMOS_DATABASE=db-agent

# ===========================================
# Azure AI Search
# ===========================================
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_API_KEY=your-search-api-key
AZURE_SEARCH_INDEX_NAME=db-agent-schema

# ===========================================
# Azure OpenAI
# ===========================================
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
EMBEDDING_DIM=3072

# ===========================================
# 애플리케이션 설정
# ===========================================
DEFAULT_TENANT_ID=your-tenant-id
DEFAULT_TENANT_NAME=your-tenant-name
SCHEDULER_INTERVAL_MINUTES=60
SCHEDULER_DEFAULT_INTERVAL_MINUTES=60
